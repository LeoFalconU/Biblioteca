<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.biblioteca.controller.MenuController"
            prefWidth="850" prefHeight="580"
            style="-fx-background-color: #1a1a2e;">


    <left>
        <VBox spacing="8" prefWidth="200"
              style="-fx-background-color: #16213e; -fx-padding: 30 15;">

            <Label text="📚 BIBLIOTECA"
                   style="-fx-text-fill: #e94560;
                          -fx-font-size: 16px;
                          -fx-font-weight: bold;"/>

            <Separator style="-fx-background-color: #e94560;"/>

            <Button text="✚  Agregar Libro"
                    onAction="#irAgregarLibro"
                    prefWidth="170"
                    style="-fx-background-color: #0f3460;
                           -fx-text-fill: #ffffff;
                           -fx-font-size: 13px;
                           -fx-padding: 12 15;
                           -fx-background-radius: 8;
                           -fx-cursor: hand;
                           -fx-alignment: CENTER-LEFT;"/>

            <Button text="🔍  Buscar Libro"
                    onAction="#irBuscarLibro"
                    prefWidth="170"
                    style="-fx-background-color: #0f3460;
                           -fx-text-fill: #ffffff;
                           -fx-font-size: 13px;
                           -fx-padding: 12 15;
                           -fx-background-radius: 8;
                           -fx-cursor: hand;
                           -fx-alignment: CENTER-LEFT;"/>


            <Region VBox.vgrow="ALWAYS"/>

            <Separator style="-fx-background-color: #533483;"/>
            <Button text="⏻  Cerrar Sesión"
                    onAction="#cerrarSesion"
                    prefWidth="170"
                    style="-fx-background-color: #e94560;
                           -fx-text-fill: #ffffff;
                           -fx-font-size: 12px;
                           -fx-padding: 10 15;
                           -fx-background-radius: 8;
                           -fx-cursor: hand;"/>
        </VBox>
    </left>


    <center>
        <StackPane fx:id="contenedor"
                   style="-fx-background-color: #1a1a2e; -fx-padding: 20;">

            <VBox alignment="CENTER" spacing="15">
                <Label text="📚"   style="-fx-font-size: 70px;"/>
                <Label text="Bienvenido a la Biblioteca"
                       style="-fx-text-fill: #e94560;
                              -fx-font-size: 22px;
                              -fx-font-weight: bold;"/>
                <Label text="Selecciona una opción del menú para comenzar."
                       style="-fx-text-fill: #aaaaaa; -fx-font-size: 14px;"/>
            </VBox>
        </StackPane>
    </center>

</BorderPane>
